# Puerto del servidor
PORT=3000

# Secreto para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=your_jwt_secret_here

# Credenciales de login (AUTH_PASSWORD en texto plano; el hash se genera automáticamente al arrancar)
AUTH_USER=your_username_here
AUTH_PASSWORD=your_password_here

# API Key de Groq — obtener en https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
